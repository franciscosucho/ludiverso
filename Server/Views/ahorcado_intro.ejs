<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ahorcado - Ludiverso</title>
    <link rel="stylesheet" href="/Estilo/estilo.css">
    <style>
        .area-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            padding: 20px;
        }
        .area-card {
            background: #fff;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
            cursor: pointer;
        }
        .area-card:hover {
            transform: translateY(-5px);
        }
        .area-card img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 50%;
            margin-bottom: 15px;
        }
        .area-card h3 {
            margin: 10px 0;
            color: #333;
        }
        .area-card p {
            color: #666;
            font-size: 0.9em;
        }
    </style>
</head>
<body>
    <%- include('header') %>
    
    <div class="container">
        <h1>Juego del Ahorcado</h1>
        <p>Selecciona un área para comenzar a jugar. ¡Demuestra tus conocimientos!</p>
        
        <div class="area-container">
            <% areas.forEach(area => { %>
                <div class="area-card" onclick="seleccionarArea(<%= area.materia_id %>)">
                    <img src="/Resources/Imagenes/<%= area.nombre.toLowerCase() %>.png" alt="<%= area.nombre %>">
                    <h3><%= area.nombre %></h3>
                    <p><%= area.descripcion %></p>
                </div>
            <% }); %>
        </div>
    </div>

    <script>
        function seleccionarArea(materiaId) {
            window.location.href = `/ahorcado?materia=${materiaId}`;
        }
    </script>
</body>
</html> 